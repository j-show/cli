{
  "name": "@jshow/cli",
  "version": "1.0.3",
  "description": "A simple CLI tool for j-show",
  "license": "MIT",
  "homepage": "https://github.com/j-show/cli",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/j-show/cli.git"
  },
  "bugs": {
    "url": "https://github.com/j-show/cli/issues"
  },
  "keywords": [
    "cli",
    "jshow",
    "jshow-cli"
  ],
  "files": [
    "dist",
    "bin",
    "README.md",
    "README_CN.md"
  ],
  "bin": {
    "jshow": "./bin/cli.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "engines": {
    "pnpm": ">=10"
  },
  "scripts": {
    "prepare": "husky",
    "clean": "rm -rf ./dist && rm -rf ./out",
    "eslint": "eslint --config ./eslint.config.js --fix --quiet --no-warn-ignored",
    "build": "pnpm clean && vite build",
    "test": "vitest --run",
    "cli": "node ./scripts/run-cli-help.mjs",
    "start": "cd ./src && ts-node ./cli.ts"
  },
  "dependencies": {
    "@jshow/logger": "latest",
    "commander": "^14",
    "inquirer": "^13",
    "semver": "^7.7.3",
    "ts-node": "^10.9.2",
    "tslib": "latest",
    "typescript": "^5"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/semver": "^7.7.1",
    "eslint": "^9",
    "eslint-config-jshow": "latest",
    "eslint-config-prettier": "latest",
    "eslint-plugin-jshow": "latest",
    "eslint-plugin-prettier": "latest",
    "husky": "latest",
    "lint-staged": "latest",
    "prettier": ">=3",
    "typescript-eslint": "^8",
    "vite": "^7",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4"
  },
  "ts-node": {
    "esm": true,
    "compilerOptions": {
      "target": "ESNext",
      "module": "NodeNext",
      "moduleResolution": "NodeNext",
      "allowJs": true,
      "experimentalDecorators": true,
      "emitDecoratorMetadata": true,
      "esModuleInterop": true,
      "allowSyntheticDefaultImports": true,
      "resolveJsonModule": true,
      "skipLibCheck": true
    }
  }
}
